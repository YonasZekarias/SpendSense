{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "strictNullChecks": true,
    "lib": ["ES2015", "DOM", "DOM.Iterable"],
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "build", "node_modules"]
}