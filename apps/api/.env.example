# server/.env

# Database Configuration
DB_NAME=spendsense_db
DB_USER=postgres
DB_PASSWORD=your_super_secret_password_here
DB_HOST=localhost
DB_PORT=5432

# You should also move your Django secret key here!
SECRET_KEY=your-django-insecure-secret-key-replace-me
DEBUG=True

# Week 3 — password reset emails (Next.js reset page reads ?uid=&token=)
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_FRONTEND_PATH=/reset-password
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret
# Optional: DEFAULT_FROM_EMAIL=SpendSense <noreply@example.com>
# Production: EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend + SMTP settings